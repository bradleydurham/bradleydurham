---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p>© {today.getFullYear()} Bradley Durham</p>
		<button class="theme-toggle" id="theme-toggle" aria-label="Switch to dark mode">
			<svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
			</svg>
			<svg class="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="12" cy="12" r="5"/>
				<line x1="12" y1="1" x2="12" y2="3"/>
				<line x1="12" y1="21" x2="12" y2="23"/>
				<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
				<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
				<line x1="1" y1="12" x2="3" y2="12"/>
				<line x1="21" y1="12" x2="23" y2="12"/>
				<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
				<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
			</svg>
		</button>
	</div>
</footer>

<script>
	const html = document.documentElement;
	const btn = document.getElementById('theme-toggle') as HTMLButtonElement | null;

	function syncButton() {
		const isDark = html.getAttribute('data-theme') === 'dark';
		btn?.classList.toggle('is-dark', isDark);
		if (btn) btn.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
	}

	btn?.addEventListener('click', () => {
		const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
		html.setAttribute('data-theme', next);
		localStorage.setItem('theme', next);
		syncButton();
	});

	syncButton();
</script>

<style>
	footer {
		padding: 0 1.25rem 3rem;
	}
	.footer-inner {
		max-width: 960px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		border-top: 1px solid var(--border);
		padding-top: 1.5rem;
	}
	p {
		margin: 0;
		font-size: 0.875rem;
		color: var(--text-muted);
	}
	.theme-toggle {
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.375rem;
		color: var(--text-muted);
		border-radius: 6px;
		display: flex;
		align-items: center;
		line-height: 0;
		transition: color 0.15s, background 0.15s;
	}
	.theme-toggle:hover {
		color: var(--text);
		background: rgba(128, 128, 128, 0.12);
	}
	.icon-sun { display: none; }
	.icon-moon { display: block; }
	.is-dark .icon-sun { display: block; }
	.is-dark .icon-moon { display: none; }
</style>
