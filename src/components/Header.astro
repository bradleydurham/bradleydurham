---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-title">{SITE_TITLE}</a>
		<div class="nav-links">
			<HeaderLink href="/blog">Writing</HeaderLink>
			<HeaderLink href="/photos">Photos</HeaderLink>
			<HeaderLink href="/now">Now</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		padding: 0 1.25rem;
	}
	nav {
		max-width: 960px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 56px;
	}
	.site-title {
		font-family: var(--font-signature), cursive;
		font-weight: 400;
		font-size: 1.75rem;
		text-decoration: none;
		color: var(--text);
		line-height: 1;
	}
	.site-title:hover {
		color: var(--accent);
	}
	.nav-links {
		display: flex;
		gap: 1.5rem;
	}
</style>
