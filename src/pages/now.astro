---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import now from '../data/now.json';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Now — ${SITE_TITLE}`} description="What I'm up to lately" />
	</head>
	<body>
		<Header />
		<main class="prose">
			<h1>Now</h1>
			<p class="updated">Updated {now.updatedAt} &middot; {now.location}</p>

			<h2>Reading</h2>
			<p>{now.reading.title}{now.reading.author ? ` — ${now.reading.author}` : ''}</p>

			<hr />

			<h2>Watching</h2>
			<p class="entry">
				<span class="title">{now.watching.title}</span>
				{now.watching.service && <span class="service">{now.watching.service}</span>}
			</p>

			<hr />

			<h2>Listening</h2>
			<p class="entry">
				<span class="title">{now.listening.title}</span>
				{now.listening.service && <span class="service">{now.listening.service}</span>}
			</p>

			<hr />

			<h2>Working on</h2>
			<p>{now.workingOn.title} — {now.workingOn.description}</p>

			<hr />

			<h2>Thinking about</h2>
			<p>{now.thinkingAbout}</p>

			<hr />

			<h2>Watchlist</h2>

			{now.watchlist?.movies?.length > 0 && (
				<Fragment>
					<h3>Movies</h3>
					<ul class="watchlist">
						{now.watchlist.movies.map((item: { title: string; service: string }) => (
							<li class="entry">
								<span class="title">{item.title}</span>
								{item.service && <span class="service">{item.service}</span>}
							</li>
						))}
					</ul>
				</Fragment>
			)}

			{now.watchlist?.tvShows?.length > 0 && (
				<Fragment>
					<h3>TV Shows</h3>
					<ul class="watchlist">
						{now.watchlist.tvShows.map((item: { title: string; service: string }) => (
							<li class="entry">
								<span class="title">{item.title}</span>
								{item.service && <span class="service">{item.service}</span>}
							</li>
						))}
					</ul>
				</Fragment>
			)}

			{now.watchlist?.documentaries?.length > 0 && (
				<Fragment>
					<h3>Documentaries</h3>
					<ul class="watchlist">
						{now.watchlist.documentaries.map((item: { title: string; service: string }) => (
							<li class="entry">
								<span class="title">{item.title}</span>
								{item.service && <span class="service">{item.service}</span>}
							</li>
						))}
					</ul>
				</Fragment>
			)}

			{now.watchlist?.sports?.length > 0 && (
				<Fragment>
					<h3>Sports</h3>
					<ul class="watchlist">
						{now.watchlist.sports.map((item: { title: string; service: string }) => (
							<li class="entry">
								<span class="title">{item.title}</span>
								{item.service && <span class="service">{item.service}</span>}
							</li>
						))}
					</ul>
				</Fragment>
			)}

			{!now.watchlist?.movies?.length && !now.watchlist?.tvShows?.length && !now.watchlist?.documentaries?.length && !now.watchlist?.sports?.length && (
				<p class="footnote">Nothing queued up yet.</p>
			)}

			<hr />
			<p class="footnote">
				A <a href="https://nownownow.com/about">/now page</a> is a snapshot of what someone's
				focused on at a given point in time. Updated whenever things change.
			</p>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		margin-top: 0;
		margin-bottom: 0.25rem;
	}
	.updated {
		font-size: 0.875rem;
		color: var(--text-muted);
		margin: 0 0 2rem;
	}
	h2 {
		font-size: 1rem;
		font-weight: 700;
		color: var(--accent);
		margin: 1.75rem 0 0.375rem;
	}
	.footnote {
		font-size: 0.875rem;
		color: var(--text-muted);
	}
	h3 {
		font-size: 0.875rem;
		font-weight: 700;
		margin: 1.25rem 0 0.375rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--text-muted);
	}
	.watchlist {
		padding-left: 1.25rem;
		margin: 0;
	}
	.watchlist li {
		margin: 0.375rem 0;
	}
	.entry {
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
	}
	.title {
		font-size: inherit;
	}
	.service {
		font-size: 0.75rem;
		color: var(--text-muted);
	}
	.watchlist li.strikethrough .title,
	.watchlist li.strikethrough .service {
		text-decoration: line-through;
		opacity: 0.45;
	}
</style>
